# =======================================================
# Moon_Dance 项目 .gitignore
# =======================================================

# -------------------------------------------------------
# 运行时产生的数据文件（服务运行时持续写入，不应纳入版本控制）
# -------------------------------------------------------
# 实时传感器日志
Moon_Dance/Moon_Dance/data/realtime_logs/*.jsonl
Moon_Dance/Moon_Dance/data/realtime_logs/processed_ids.json

# Excel 报表（自动生成，体积大，不入版本控制）
Moon_Dance/Moon_Dance/data/reports/
Moon_Dance/batch_reports/

# 运行日志
Moon_Dance/logs/
Moon_Dance/Moon_Dance/logs/

# 临时文件与 MQ PID 文件
Moon_Dance/tmp/
Moon_Dance/Moon_Dance/tmp/

# -------------------------------------------------------
# Python
# -------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# -------------------------------------------------------
# 虚拟环境
# -------------------------------------------------------
venv/
env/
.venv/
.env/

# -------------------------------------------------------
# TLS 证书（本地开发用，不提交）
# -------------------------------------------------------
Moon_Dance/Moon_Dance/certs/

# -------------------------------------------------------
# IDE & 系统文件
# -------------------------------------------------------
.vscode/
.idea/
*.DS_Store
Thumbs.db

# -------------------------------------------------------
# 打包产物
# -------------------------------------------------------
*.exe
*.spec
dist/
